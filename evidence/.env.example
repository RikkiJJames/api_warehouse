# Copy to .env and fill in. Same Postgres instance ingest/dbt use — see
# ingest/src/db/core/db.py for the equivalent DB_HOST/DB_NAME/DB_USER/
# DB_PASSWORD/DB_PORT vars there.
#
# For local dev, point HOST/PORT at a Cloud SQL Auth Proxy tunnel
# (127.0.0.1:5432) rather than the instance directly.
EVIDENCE_SOURCE__WAREHOUSE__HOST=127.0.0.1
EVIDENCE_SOURCE__WAREHOUSE__PORT=5432
EVIDENCE_SOURCE__WAREHOUSE__DATABASE=warehouse
EVIDENCE_SOURCE__WAREHOUSE__USER=
EVIDENCE_SOURCE__WAREHOUSE__PASSWORD=
