FROM python:3.12-slim

WORKDIR /usr/app

# install uv
RUN pip install uv

# copy dependency files first (for caching)
COPY pyproject.toml uv.lock ./

# install deps using uv
RUN uv sync --frozen

# copy ingest app
COPY . .

ENV PATH="/usr/app/.venv/bin:$PATH"

CMD ["uv", "run", "python", "main.py"]
